APP_NAME=Bowdoin CED Job Tracker
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/jobs_tracker
LLM_PROVIDER=bedrock

# Direct Anthropic option (only if LLM_PROVIDER=anthropic)
CLAUDE_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Bedrock option (default)
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
# Prefer standard AWS env vars when possible:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# Optional profile name if using local AWS config:
# AWS_PROFILE=
CSV_INPUT_PATH=employers.csv
CSV_OUTPUT_PATH=data/processed/employers_with_urls.csv
ENRICHMENT_CONCURRENCY=5
REQUEST_TIMEOUT_SECONDS=30
MAX_RETRIES=3
