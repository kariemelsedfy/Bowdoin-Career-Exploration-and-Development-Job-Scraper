APP_NAME=Bowdoin CED Job Tracker
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/jobs_tracker

# Bedrock config (Anthropic Claude model hosted in Bedrock)
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Bedrock auth option A (API key auth from AWS docs)
AWS_BEARER_TOKEN_BEDROCK=replace_me

# Bedrock auth option B: direct AWS credentials
# AWS_ACCESS_KEY_ID=replace_me
# AWS_SECRET_ACCESS_KEY=replace_me
# AWS_SESSION_TOKEN=replace_me_if_temporary_creds

# Bedrock auth option C: local AWS profile
# AWS_PROFILE=your-profile-name

# CSV/job settings
CSV_INPUT_PATH=employers.csv
CSV_OUTPUT_PATH=data/processed/employers_with_urls.csv
ENRICHMENT_CONCURRENCY=5
REQUEST_TIMEOUT_SECONDS=30
MAX_RETRIES=3
